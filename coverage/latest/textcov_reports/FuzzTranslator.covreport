  179|      1|    mutating func resizeFrameHeader(sp: inout Sp, immediate: Instruction.ResizeFrameHeaderOperand) throws {
  180|      1|        // The params/results space are resized by `delta` slots and the rest of the
  181|      1|        // frame is copied to the new location. See the following diagram for the
  182|      1|        // layout of the frame before and after the resize operation:
  183|      1|        //
  184|      1|        //
  185|      1|        //              |--------BEFORE-------|   |--------AFTER--------|
  186|      1|        //              |  Params  | Results  |   |  Params  | Results  |
  187|      1|        //              |  ...     |   ...    |   |  ...     |   ...    |
  188|      1|        // Old Header ->|---------------------|\  |  ...     |   ...    |              -+
  189|      1|        //              |         Sp          | \ |  ...     |   ...    |               | delta
  190|      1|        //              |---------------------|  \|---------------------|<- New Header -+  -+
  191|      1|        //              |         Pc          |   |         Sp          |                   |
  192|      1|        //              |---------------------|   |---------------------|                   |
  193|      1|        //              |     Current Func    | C |         Pc          |                   |
  194|      1|        //     Old Sp ->|---------------------| O |---------------------|                   |
  195|      1|        //              |       Locals        | P |     Current Func    |                   |
  196|      1|        //              |        ...          | Y |---------------------|<- New Sp          |
  197|      1|        //              |---------------------|   |       Locals        |                   | sizeToCopy
  198|      1|        //              |        Consts       |   |        ...          |                   |
  199|      1|        //              |        ...          |   |---------------------|                   |
  200|      1|        //              |---------------------|   |        Consts       |                   |
  201|      1|        //              |     Value Stack     |   |        ...          |                   |
  202|      1|        //              |        ...          |   |---------------------|                   |
  203|      1|        //              |---------------------|\  |     Value Stack     |                   |
  204|      1|        //                                      \ |        ...          |                   |
  205|      1|        //                                       \|---------------------|                  -+
  206|      1|        let newSp = sp.advanced(by: Int(immediate.delta))
  207|      1|        try checkStackBoundary(newSp)
  208|      1|        let oldFrameHeader = sp.advanced(by: -FrameHeaderLayout.numberOfSavingSlots)
  209|      1|        let newFrameHeader = newSp.advanced(by: -FrameHeaderLayout.numberOfSavingSlots)
  210|      1|        newFrameHeader.update(from: oldFrameHeader, count: Int(immediate.sizeToCopy))
  211|      1|        sp = newSp
  212|      1|    }

